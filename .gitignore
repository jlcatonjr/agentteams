__pycache__/
*.pyc
*.pyo
.venv/
dist/
*.egg-info/
.DS_Store
.pytest_cache/
htmlcov/
*.swp
*.swa
*~

# Generated agent team for this repo — excluded because the team's
# knowledge of the module's internals could compromise the repository
# if exposed as context to external users.
# Uses /* instead of / so we can un-ignore _build-description.json for CI.
.github/agents/*
.github/copilot-instructions.md

# Build-time intake artifacts (written by the team-builder agent)
_build-description.json
_intake-notes.md
# Un-ignore the self-team description so CI can run security-maintenance.
# Must come AFTER the _build-description.json pattern above (last rule wins).
!.github/agents/_build-description.json

# Planning and step CSVs
build-team-steps.csv
tool-enrichment-steps.csv

# Automatic pre-write backups created by build_team.py
.agentteams-backups/

# MkDocs local build output — rebuilt by CI; never committed
_site/

# Operational scratch space — contains absolute machine paths and private repo names (OPSEC S-1)
# Nothing in tmp/ should ever be committed; sanitize before moving anything to a permanent location
tmp/

# Harness-generated, machine-local permission state (RRM1). Scoped to the single
# file — other .claude/ files (README.md, agent-team.md, quickstart-snippet.md)
# are tracked and must NOT be ignored.
.claude/settings.json

# Daily work summaries — operational logs and tracking documents
# Contains execution dates, timestamps, and per-repo status; not for publication
workSummaries/

# Canonical home for RETAINED local planning/operation docs (plans, feasibility
# reports, investigations, change reports) — not for publication; may contain
# machine-specific paths and org/repo names. See references/filing-conventions.md.
# Plan documents must NEVER be written to the repo root (guard: tests/test_root_doc_hygiene.py).
references/plans/

# Generated bridge-merge run reports — regenerated by the bridge tooling and
# contain machine-specific absolute paths; keep local, never publish.
references/bridges/**/bridge-merge.report.md

# Structural or audit plan docs committed during development
docs_src/structural-update-plan.md
python

# Stale root-level templates/ — canonical copy is agentteams/templates/
/templates/

# SVG build artifacts — regenerated on demand via graph module
# Regenerate with: python -m agentteams.graph .github/agents/ --format svg
docs/book/figures/*.svg
docs_src/book/figures/*.svg
!docs/book/figures/agent-team-structure.svg
!docs_src/book/figures/agent-team-structure.svg
!docs/book/figures/workflow-12-adaptive-plan-execution.svg
!docs_src/book/figures/workflow-12-adaptive-plan-execution.svg
