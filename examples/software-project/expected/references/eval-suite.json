{
  "artifact_type": "eval-suite",
  "eval_suite_schema_version": "1.0",
  "project_name": "WebAppBackend",
  "framework": "copilot-vscode",
  "generated_from": "manifest",
  "scenarios": [
    {
      "id": "routing-orchestrator-knows-all-experts",
      "category": "routing",
      "claim": "The orchestrator's agents: list includes every workstream expert, so it can route to each declared component.",
      "predicate": {
        "kind": "frontmatter-list-contains-all",
        "file": "orchestrator.agent.md",
        "field": "agents",
        "values": [
          "auth-module-expert",
          "tasks-api-expert"
        ]
      }
    },
    {
      "id": "routing-expert-count-matches-components",
      "category": "routing",
      "claim": "Exactly 2 workstream-expert agent file(s) are emitted for 2 declared component(s).",
      "predicate": {
        "kind": "agent-count",
        "suffix": "-expert.agent.md",
        "count": 2
      }
    },
    {
      "id": "governance-auth-module-triad-and-return",
      "category": "governance",
      "claim": "auth-module-expert wires the worker-governance triad (primary-producer, adversarial, reference-manager) and includes a 'Return to Orchestrator' edge.",
      "predicate": {
        "kind": "frontmatter-and-body",
        "file": "auth-module-expert.agent.md",
        "agents_contains_all": [
          "primary-producer",
          "adversarial",
          "reference-manager"
        ],
        "body_contains": "Return to Orchestrator"
      }
    },
    {
      "id": "handoff-tasks-api",
      "category": "handoff",
      "claim": "tasks-api-expert receives upstream from auth-module-expert and returns to the orchestrator (coordination is orchestrator-mediated, not peer-to-peer).",
      "predicate": {
        "kind": "handoff-chain",
        "chain": [
          "auth-module-expert",
          "tasks-api-expert"
        ],
        "returns_to": "orchestrator"
      }
    },
    {
      "id": "governance-tasks-api-triad-and-return",
      "category": "governance",
      "claim": "tasks-api-expert wires the worker-governance triad (primary-producer, adversarial, reference-manager) and includes a 'Return to Orchestrator' edge.",
      "predicate": {
        "kind": "frontmatter-and-body",
        "file": "tasks-api-expert.agent.md",
        "agents_contains_all": [
          "primary-producer",
          "adversarial",
          "reference-manager"
        ],
        "body_contains": "Return to Orchestrator"
      }
    }
  ]
}
