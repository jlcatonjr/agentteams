{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "repo-inventory/v1.schema.json",
  "title": "Repository Inventory Manifest",
  "description": "Payload handed from the inventory-expert to the categorize-expert: the classified set of tracked files plus the off-limits untracked set.",
  "type": "object",
  "required": ["repo_root", "tracked_files", "untracked_offlimits"],
  "additionalProperties": false,
  "properties": {
    "repo_root": {
      "type": "string"
    },
    "tracked_files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "kind"],
        "additionalProperties": false,
        "properties": {
          "path": {"type": "string"},
          "kind": {
            "type": "string",
            "enum": ["corpus", "generated-html", "notebook", "model-output", "document", "code", "other"]
          }
        }
      }
    },
    "untracked_offlimits": {
      "type": "array",
      "items": {"type": "string"}
    }
  }
}
