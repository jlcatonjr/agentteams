{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "handoff-payload-meta.schema.json",
  "title": "Handoff Payload Meta-Schema",
  "description": "Constraints every concrete handoff payload schema must satisfy.",
  "type": "object",
  "required": ["$id", "type", "properties", "required", "additionalProperties"],
  "properties": {
    "$id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+/v[0-9]+\\.schema\\.json$",
      "description": "Versioned identifier of the form <slug>/v<n>.schema.json"
    },
    "type": {
      "const": "object"
    },
    "properties": {
      "type": "object",
      "minProperties": 1
    },
    "required": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string"}
    },
    "additionalProperties": {
      "const": false
    }
  }
}
